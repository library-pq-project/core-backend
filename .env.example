APP_NAME=AI Exam Prep Backend
APP_VERSION=0.1.0
API_PREFIX=/api
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/exam_prep
JWT_SECRET_KEY=change-this-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
UPLOAD_DIR=uploads
FILE_STORAGE_PROVIDER=local
S3_ENDPOINT_URL=
S3_BUCKET_NAME=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
MAX_ATTEMPT_DURATION_MINUTES=180
AI_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
GEMINI_TIMEOUT_SECONDS=30
GEMINI_MAX_RETRIES=2
